# JobHunt Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=jobhunt
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://jobhunt:your_secure_password_here@localhost:5433/jobhunt_db

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6381/0

# =============================================================================
# MINIO (S3-Compatible Storage)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here

# =============================================================================
# TEMPORAL
# =============================================================================
TEMPORAL_ADDRESS=localhost:7233

# =============================================================================
# LLM (OpenAI-compatible; defaults to xAI Grok)
# =============================================================================
# The pipeline talks to any OpenAI-compatible chat-completions endpoint.
# Defaults target xAI Grok; override these to use OpenAI, a local vLLM/Ollama
# server, or any compatible gateway.
LLM_API_KEY=your_llm_api_key_here            # falls back to XAI_API_KEY if unset
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-4-1-fast
LLM_LIGHT_MODEL=grok-3-fast                   # cheaper model for classify/extract

# Back-compat alias for LLM_API_KEY (also used by the xAI Grok web-search connector)
XAI_API_KEY=your_xai_api_key_here

# OpenAI API (only if you enable embeddings)
OPENAI_API_KEY=

# =============================================================================
# JOB SEARCH APIs
# =============================================================================
# SerpAPI for Google Jobs search
SERPAPI_KEY=your_serpapi_key_here

# Apollo.io for company/contact enrichment
APOLLO_API_KEY=your_apollo_api_key_here

# LinkedIn API (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Indeed API (optional)
INDEED_PUBLISHER_ID=

# =============================================================================
# GOOGLE OAUTH (for Gmail integration)
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8084/oauth/callback

# =============================================================================
# EMAIL (SMTP for sending)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
SMTP_FROM_NAME=Your Name
SMTP_FROM_EMAIL=your_email@gmail.com

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode
DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API rate limiting
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# CANDIDATE PROFILE
# =============================================================================
# Personal details (name, contact, background, resume) live in a YAML profile,
# never in code. Copy profile.example.yaml to data/profile.yaml and edit it,
# or point PROFILE_PATH at your own file. Falls back to generic defaults.
# PROFILE_PATH=/app/data/profile.yaml

# =============================================================================
# RESUME & PROFILE
# =============================================================================
# Path to your resume PDF (for parsing)
RESUME_PATH=/app/data/resume.pdf

# Your target job titles (comma-separated)
TARGET_JOB_TITLES=Software Engineer,Senior Software Engineer,Staff Engineer

# Target locations (comma-separated)
TARGET_LOCATIONS=San Francisco,Remote,New York

# Minimum salary (optional)
MIN_SALARY=150000

# =============================================================================
# NOTIFICATIONS (Optional)
# =============================================================================
# Slack webhook for notifications
SLACK_WEBHOOK_URL=

# Discord webhook (optional)
DISCORD_WEBHOOK_URL=

# =============================================================================
# PRODUCTION - Only needed for production deployment
# =============================================================================
# Managed/RDS Postgres connection for the JobHunt database
# JOBHUNT_DATABASE_URL=postgresql://jobhunt_user:password@your-db-host.example.com:5432/jobhunt_db

# Admin connection for migrations (RLS bypass)
# JOBHUNT_DATABASE_URL_ADMIN=postgresql://admin_user:password@your-db-host.example.com:5432/jobhunt_db

# Production API key
# JOBHUNT_API_KEY=your_production_api_key

# OAuth master key for encrypting stored OAuth tokens (generate 32 random bytes)
# OAUTH_MASTER_KEY=your_32_byte_key_here
